---
interface Props {
  brand?: string;
  tagline?: string;
}

const {
  brand = 'Brandname',
  tagline = 'A clean, fast, modern starting point.',
} = Astro.props;

const year = new Date().getFullYear();
---

<footer class="relative mx-auto max-w-7xl px-6 pb-16 pt-12">
  <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-8">
    <div class="grid gap-8 sm:grid-cols-3">
      <div>
        <div class="flex items-center gap-2 font-semibold">
          <span class="grid h-7 w-7 place-items-center rounded-md bg-gradient-to-br from-accent-500 to-pink-500 text-sm text-white">✦</span>
          {brand}
        </div>
        <p class="mt-3 text-sm text-slate-400">{tagline}</p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-slate-300">Product</h4>
        <ul class="mt-3 space-y-2 text-sm text-slate-400">
          <li><a href="#features" class="hover:text-white">Features</a></li>
          <li><a href="#pricing" class="hover:text-white">Pricing</a></li>
          <li><a href="#cta" class="hover:text-white">Get started</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-slate-300">Company</h4>
        <ul class="mt-3 space-y-2 text-sm text-slate-400">
          <li><a href="#about" class="hover:text-white">About</a></li>
          <li><a href="mailto:hello@example.com" class="hover:text-white">Contact</a></li>
          <li><a href="#" class="hover:text-white">Privacy</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 border-t border-white/5 pt-6 text-center text-xs text-slate-500">
      © {year} {brand}. All rights reserved.
    </div>
  </div>
</footer>
